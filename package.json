{
  "name": "tyravel",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build --workspace=@tyravel/cli",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "tyravel": "node packages/cli/dist/bin/tyravel.js"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}