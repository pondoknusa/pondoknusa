{
  "name": "tyravel",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "build": "tsc -b && npm run build --workspace=@tyravel/cli",
    "check:node": "node scripts/check-node.mjs",
    "pretest": "npm run check:node",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretypecheck": "npm run check:node",
    "typecheck": "tsc -b",
    "docs:generate": "node scripts/generate-docs.mjs",
    "predocs:build": "npm run docs:generate",
    "predocs:dev": "npm run docs:generate",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "tyravel": "node packages/cli/dist/bin/tyravel.js",
    "prebenchmark": "npm run build",
    "benchmark": "node scripts/benchmark.mjs",
    "release:prepare": "node scripts/prepare-release.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.8.3",
    "vitepress": "^1.6.3",
    "vitest": "^3.2.4"
  }
}
