    "@pondoknusa/broadcasting": "2.0.4",
    "@pondoknusa/container": "2.0.4",
    "@pondoknusa/core": "2.0.4",
    "@pondoknusa/database": "2.0.4",
    "@pondoknusa/http": "2.0.4",
    "@pondoknusa/mail": "2.0.4",
    "@pondoknusa/notifications": "2.0.4",
    "@pondoknusa/views": "2.0.4"
