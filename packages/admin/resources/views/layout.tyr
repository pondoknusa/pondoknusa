<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>@yield('title', 'Admin')</title>
  <style>
    :root { color-scheme: light dark; font-family: system-ui, sans-serif; }
    body { margin: 0; background: #f4f4f5; color: #18181b; }
    .admin-shell { display: grid; grid-template-columns: 220px 1fr; min-height: 100vh; }
    .admin-nav { background: #18181b; color: #fafafa; padding: 1.25rem; }
    .admin-nav h1 { font-size: 1rem; margin: 0 0 1rem; }
    .admin-nav a { display: block; color: #d4d4d8; text-decoration: none; padding: 0.35rem 0; }
    .admin-nav a:hover, .admin-nav a.active { color: #fff; }
    .admin-main { padding: 1.5rem 2rem; }
    .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .admin-card { background: #fff; border: 1px solid #e4e4e7; border-radius: 0.5rem; padding: 1rem; }
    table { width: 100%; border-collapse: collapse; }
    th, td { text-align: left; padding: 0.65rem 0.75rem; border-bottom: 1px solid #e4e4e7; }
    .btn { display: inline-block; padding: 0.45rem 0.85rem; border-radius: 0.375rem; border: 1px solid #d4d4d8; background: #fff; color: #18181b; text-decoration: none; cursor: pointer; }
    .btn-primary { background: #18181b; color: #fff; border-color: #18181b; }
    .btn-danger { background: #dc2626; color: #fff; border-color: #dc2626; }
    .toolbar { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1rem; align-items: center; }
    .field { margin-bottom: 1rem; }
    .field label { display: block; font-weight: 600; margin-bottom: 0.35rem; }
    .field input, .field select, .field textarea { width: 100%; max-width: 32rem; padding: 0.5rem; border: 1px solid #d4d4d8; border-radius: 0.375rem; }
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; }
    .stat { padding: 1rem; border: 1px solid #e4e4e7; border-radius: 0.5rem; background: #fafafa; }
    .pagination { display: flex; gap: 0.5rem; margin-top: 1rem; }
  </style>
</head>
<body>
  <div class="admin-shell">
    <aside class="admin-nav">
      <h1><a href="{{ prefix }}">Admin</a></h1>
      <nav>
        <a href="{{ prefix }}">Dashboard</a>
        @foreach (resources as entry)
          <a href="{{ prefix }}/{{ entry.key }}" @class(['active' => resource && resource.key === entry.key])>{{ entry.label }}</a>
        @endforeach
      </nav>
    </aside>
    <main class="admin-main">
      @yield('content')
    </main>
  </div>
</body>
</html>