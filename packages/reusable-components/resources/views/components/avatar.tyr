@props(['src' => null, 'alt' => '', 'size' => 40, 'initials' => null])

@if (src)
  <img class="ui-avatar" src="{{ src }}" alt="{{ alt }}" width="{{ size }}" height="{{ size }}" {!! $attributes.toHtml() !!} />
@else
  <span class="ui-avatar ui-avatar--initials" style="width: {{ size }}px; height: {{ size }}px;" {!! $attributes.toHtml() !!}>{{ initials }}</span>
@endif